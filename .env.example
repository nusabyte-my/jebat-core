# JEBAT Environment Configuration
# Copy this file to .env and fill in your values

# System Configuration
JEBAT_NAME=JEBAT
JEBAT_VERSION=2.0.0
JEBAT_DEBUG=false
JEBAT_LOG_LEVEL=INFO

# Core Settings
JEBAT_MEMORY_LAYERS=5
JEBAT_MEMORY_CONSOLIDATION_INTERVAL=3600
JEBAT_AGENTS_MAX_CONCURRENT=10

# Ultra-Think Settings
JEBAT_ULTRA_THINK_ENABLED=true
JEBAT_ULTRA_THINK_MAX_THOUGHTS=20
JEBAT_ULTRA_THINK_MODE=deliberate

# Ultra-Loop Settings
JEBAT_ULTRA_LOOP_ENABLED=true
JEBAT_ULTRA_LOOP_CYCLE_INTERVAL=1.0

# Sentinel Settings
JEBAT_SENTINEL_ENABLED=true
JEBAT_SENTINEL_SECURITY_LEVEL=standard

# WebUI Service
JEBAT_WEBUI_ENABLED=true
JEBAT_WEBUI_HOST=0.0.0.0
JEBAT_WEBUI_PORT=8787

# API Service
JEBAT_API_ENABLED=true
JEBAT_API_HOST=0.0.0.0
JEBAT_API_PORT=8080

# MCP Service
JEBAT_MCP_ENABLED=true
JEBAT_MCP_PORT=18789

# Database (optional)
JEBAT_DATABASE_ENABLED=false
JEBAT_DATABASE_TYPE=sqlite
JEBAT_DATABASE_URL=sqlite:///jebat.db

# API Keys (for external integrations)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Stitch MCP Integration (for JEBAT DevAssistant)
STITCH_MCP_SERVER_URL=http://localhost:8080
STITCH_MCP_API_KEY=

# ====================================================================
# JEBAT v8.2 — Environment Variables
# ====================================================================
# Copy this file to .env and customize for your deployment.
#
#   cp .env.example .env
#
# ─── SECTION 1: Docker Compose Infrastructure ──────────────────────
# Used by docker-compose.yml / docker-compose.prod.yml.
# Only passwords MUST be changed before production.
#
# ─── SECTION 2: Application Configuration ──────────────────────────
# Used by the JEBAT API and internal services.
# ====================================================================

# ────────────────────────────────────────────────────────────────────
# SECTION 1 — Docker Compose Infrastructure
# ────────────────────────────────────────────────────────────────────

# PostgreSQL credentials (jebat-api, postgres-exporter, Grafana datasources)
POSTGRES_DB=jebat_db
POSTGRES_USER=jebat
POSTGRES_PASSWORD=jebat_secure_password_change_me

# Redis password (jebat-api, redis-exporter, Grafana datasources)
REDIS_PASSWORD=redis_secure_password_change_me

# Host port mappings — change if ports conflict with other services
JEBAT_API_PORT=8080
JEBAT_WEBUI_PORT=8787
JEBAT_MCP_PORT=18789
POSTGRES_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=jebat_admin_change_me

# Production override — Grafana root URL domain (docker-compose.prod.yml)
# DOMAIN=jebat.online

# ────────────────────────────────────────────────────────────────────
# SECTION 2 — Application Configuration
# ────────────────────────────────────────────────────────────────────

# System
JEBAT_NAME=JEBAT
JEBAT_VERSION=8.2.0
JEBAT_DEBUG=false
JEBAT_LOG_LEVEL=INFO

# ELK / Elasticsearch structured logging (Catalyst observability)
# OFF by default: leave JEBAT_LOGGING_ELASTICSEARCH_URL blank to disable.
# Set the URL to enable shipping structured logs to Elasticsearch.
JEBAT_ELK_ENABLED=false
JEBAT_LOGGING_ELASTICSEARCH_URL=
JEBAT_LOGGING_ELASTICSEARCH_INDEX=jebat-logs
# Optional API key (leave blank for unauthenticated / local clusters)
JEBAT_LOGGING_ELASTICSEARCH_API_KEY=

# Core settings
JEBAT_MEMORY_LAYERS=5
JEBAT_MEMORY_CONSOLIDATION_INTERVAL=3600
JEBAT_AGENTS_MAX_CONCURRENT=10

# Ultra-Think
JEBAT_ULTRA_THINK_ENABLED=true
JEBAT_ULTRA_THINK_MAX_THOUGHTS=20
JEBAT_ULTRA_THINK_MODE=deliberate

# Ultra-Loop
JEBAT_ULTRA_LOOP_ENABLED=true
JEBAT_ULTRA_LOOP_CYCLE_INTERVAL=1.0

# Sentinel
JEBAT_SENTINEL_ENABLED=true
JEBAT_SENTINEL_SECURITY_LEVEL=standard

# CORS origins for the API (comma-separated)
JEBAT_CORS_ORIGINS=*

# LLM provider routing
JEBAT_LLM_PROVIDER=openai
JEBAT_LLM_MODEL=gpt-5.4
JEBAT_LLM_TEMPERATURE=0.2
JEBAT_LLM_MAX_TOKENS=4096
JEBAT_LLM_FALLBACKS=local

# Chat history
JEBAT_CHAT_HISTORY_PATH=.jebat/chat_history.jsonl

# ────────────────────────────────────────────────────────────────────
# SECTION 3 — API Keys (for external LLM providers)
# ────────────────────────────────────────────────────────────────────
# Leave blank to disable a provider. JEBAT will fall back to the next
# configured provider in the chain.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Ollama local (set to your Ollama host, e.g. http://localhost:11434)
OLLAMA_HOST=

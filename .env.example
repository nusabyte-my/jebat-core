# JEBAT Environment Configuration
# Copy this file to .env and fill in your values

# Application
JEBAT_ENV=production
JEBAT_LOG_LEVEL=INFO

# Database (PostgreSQL/TimescaleDB)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jebat
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jebat

# Redis
REDIS_URL=redis://localhost:6379

# Monitoring
MONITORING_API_URL=http://localhost:8000
MONITORING_REFRESH_SECONDS=2

# LLM Providers (Bring Your Own Key)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Channel Integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# Security
JEBAT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JEBAT_ENCRYPTION_KEY=changeme-32-char-base64-key

# Optional: Custom model endpoints
OLLAMA_BASE_URL=http://host.docker.internal:11434
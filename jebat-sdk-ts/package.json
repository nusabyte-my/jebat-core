{
  "name": "@jebat/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for JEBAT AI Assistant REST API",
  "license": "MIT",
  "author": "humm1ngb1rd <humm1ngb1rd@nusabyte.my>",
  "homepage": "https://github.com/humm1ngb1rd/jebat",
  "repository": {
    "type": "git",
    "url": "https://github.com/humm1ngb1rd/jebat.git",
    "directory": "jebat-sdk-ts"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "require": "./dist/client.cjs",
      "types": "./dist/client.d.ts"
    },
    "./websocket": {
      "import": "./dist/websocket.js",
      "require": "./dist/websocket.cjs",
      "types": "./dist/websocket.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "prepublishOnly": "npm run build && npm run test && npm run typecheck",
    "docs": "typedoc --out docs src"
  },
  "dependencies": {
    "zod": "^3.22.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.3.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "typedoc": "^0.25.0",
    "happy-dom": "^13.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
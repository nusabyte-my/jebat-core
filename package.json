{
  "name": "create-jebatcore",
  "version": "0.1.0",
  "description": "JEBATCore workstation installer for IDE context files and local MCP setup.",
  "type": "module",
  "bin": {
    "jebatcore": "./jebat-npm/bin/jebat.js"
  },
  "files": [
    "jebat-npm/bin"
  ],
  "keywords": [
    "jebat",
    "cli",
    "installer",
    "mcp",
    "ide",
    "ai",
    "token-optimization",
    "context-compression",
    "llm-tools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:cli": "bash scripts/build-cli-bundle.sh || scripts\\build-cli-bundle.bat",
    "build:cli:win": "scripts\\build-cli-bundle.bat",
    "build:cli:unix": "bash scripts/build-cli-bundle.sh",
    "cli:detect": "node ./jebat-npm/bin/jebat.js detect",
    "cli:doctor": "node ./jebat-npm/bin/jebat.js doctor",
    "cli:help": "node ./jebat-npm/bin/jebat.js help"
  }
}

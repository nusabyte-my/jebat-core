APP_ENV=production
JEBAT_NAME=JEBATCore
JEBAT_LOG_LEVEL=INFO
JEBAT_API_ENABLED=true
JEBAT_API_HOST=0.0.0.0
JEBAT_API_PORT=8000
JEBAT_WEBUI_ENABLED=false
JEBAT_DATABASE_ENABLED=false
JEBAT_DATABASE_TYPE=sqlite
JEBAT_DATABASE_URL=sqlite:///app/data/jebat.db
REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

JEBAT_LLM_PROVIDER=openai
JEBAT_LLM_MODEL=gpt-5.4
JEBAT_LLM_TEMPERATURE=0.2
JEBAT_LLM_MAX_TOKENS=1200
JEBAT_LLM_FALLBACKS=google,anthropic,openrouter,ollama,local
